# ============================================
# 知喻（KnowTale）环境配置模板
# 复制此文件为 .env 并填入实际配置
# ============================================

# SillyTavern 服务配置
ST_PORT=8000
ST_HOST=0.0.0.0
ST_WHITELIST=false

# API 密钥配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# Chroma 向量数据库配置
CHROMA_PERSIST_DIR=./data/chroma

# MinerU 文档解析服务配置
MINERU_SERVICE_URL=http://localhost:8001
MINERU_API_KEY=your_mineru_api_key_here

# 数据库配置
DB_PATH=./data/knowtale.db
DB_SECRET_KEY=your_db_encryption_key_here

# JWT 密钥（用于账号系统身份校验）
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72

# 学情分析周期（天）
ANALYSIS_INTERVAL_DAYS=7

# 日志级别
LOG_LEVEL=info
