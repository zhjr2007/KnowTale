# 知喻 · 环境配置

# 阿里云百炼 API（DashScope）
# 获取地址：https://bailian.console.aliyun.com/
BAILIAN_API_KEY=sk-your-bailian-api-key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型配置（默认值即可，可按需调整）
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v3
RERANK_MODEL=text-rerank-v1

# MinerU 文档解析服务（Docker sidecar）
MINERU_URL=http://localhost:8001

# 数据库 (默认 SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/knowtale.db

# JWT 密钥 (生产环境请改为复杂随机字符串)
SECRET_KEY=knowtale-secret-key-change-in-production
JWT_EXPIRATION_HOURS=168

# ChromaDB 配置
CHROMA_HOST=localhost
CHROMA_PORT=8000

# 应用配置
DEBUG=false
APP_NAME=知喻
